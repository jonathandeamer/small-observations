# Hugo build output
/public/
/resources/_gen/
.hugo_build.lock

# Photo ingest staging (originals + processed marker; never committed)
/_ingest/

# Scratch / throwaway work
/tmp/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local-only env
.env
.env.local

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Test fixtures regenerated each session by conftest.py
/tests/fixtures/

# Geocode cache (rebuildable)
.cache/
